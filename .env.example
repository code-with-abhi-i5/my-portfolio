# ─── Spotify API Credentials ───────────────────────
# 1. Go to https://developer.spotify.com/dashboard
# 2. Create an app → get Client ID & Client Secret
# 3. Set Redirect URI to: http://localhost:8888/callback
# 4. Run: node scripts/get-spotify-token.mjs
# 5. Copy the refresh_token below

SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REFRESH_TOKEN=your_refresh_token_here

# ─── Frontend Env (Vite) ──────────────────────────
# URL of your deployed Vercel app (or localhost for dev)
# Example: https://your-portfolio.vercel.app
VITE_SPOTIFY_API_URL=

# ─── GitHub API Token ─────────────────────────────
# Go to https://github.com/settings/tokens → Generate new token (classic)
# Required scopes: public_repo
VITE_GITHUB_TOKEN=your_github_token_here
